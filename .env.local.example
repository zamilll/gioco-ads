# Unified.to credentials — copy to .env.local and fill in
# Also add these to Vercel → Project → Settings → Environment Variables.

# Secret key from https://app.unified.to/keys (starts with sk_)
UNIFIED_API_TOKEN=sk_...

# Workspace id from Unified.to dashboard
UNIFIED_WORKSPACE_ID=

# Default connection id to hit on the dashboard / campaigns pages
# (the connection the app should read from when no override is given)
UNIFIED_CONNECTION_ID=

# Public app origin used as the OAuth redirect target
# Example: https://gioco-ads.vercel.app  (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
